import React, { useState, useEffect, useMemo } from 'react';
import { 
  Shield, Clock, Trash2, RotateCcw, AlertTriangle, ShieldAlert, 
  UserCheck, UserX, Plus, Database, FileText, CheckCircle2,
  ChevronDown, ChevronUp, Activity, Search, Filter, Zap,
  Lock, ShieldCheck, Key, History, Trash, Download, ArrowRight,
  Fingerprint, Eye, Ghost, Terminal, Cpu
} from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { useNavigate } from 'react-router-dom';
import { finance } from '../services/finance';
import { useAuth } from '../hooks/useAuth';
import { profilesService, UserProfile } from '../services/profiles';
import { AuditLog } from '../types';
import DeleteDataModal from '../components/DeleteDataModal';
import * as XLSX from 'xlsx';
import { cn } from '../lib/utils';

type TabType = 'audit' | 'access' | 'maintenance' | 'danger';

export default function SystemCenter() {
  const navigate = useNavigate();
  const [activeTab, setActiveTab] = useState<TabType>('audit');
  const [auditSubTab, setAuditSubTab] = useState<'logs' | 'trash'>('logs');
  
  // Data state
  const [logs, setLogs] = useState<AuditLog[]>([]);
  const [deletedItems, setDeletedItems] = useState<any[]>([]);
  const [profiles, setProfiles] = useState<UserProfile[]>([]);
  const [pendingProfiles, setPendingProfiles] = useState<UserProfile[]>([]);
  const [loading, setLoading] = useState(true);
  const [purging, setPurging] = useState(false);
  const [restoring, setRestoring] = useState<string | null>(null);
  const [isDeleteModalOpen, setIsDeleteModalOpen] = useState(false);
  const [toast, setToast] = useState<string | null>(null);

  // Access state
  const [preApproveEmail, setPreApproveEmail] = useState('');
  const [preApproveRole, setPreApproveRole] = useState<'ADMIN' | 'EDITOR' | 'VIEWER'>('EDITOR');
  const [isPreApproving, setIsPreApproving] = useState(false);
  const [presenceEnabled, setPresenceEnabled] = useState(true);
  const [savingPresence, setSavingPresence] = useState(false);

  const { profile: currentUserProfile } = useAuth();
  const isAdmin = currentUserProfile?.role === 'ADMIN';
  const isSuperAdmin = currentUserProfile?.email === 'paulovictorsilva2301@gmail.com';

  const showToast = (msg: string) => { 
    setToast(msg); 
    setTimeout(() => setToast(null), 3000); 
  };

  useEffect(() => {
    if (isAdmin) {
      loadData();
    }
  }, [isAdmin, activeTab, auditSubTab]);

  const loadData = async () => {
    setLoading(true);
    try {
      if (activeTab === 'audit') {
        if (auditSubTab === 'logs') {
          const data = await finance.getAuditLogs();
          setLogs(data.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime()));
        } else {
          const data = await finance.getDeletedItems();
          setDeletedItems(data);
        }
      } else if (activeTab === 'access') {
        const all = await profilesService.getAllProfiles();
        setProfiles(all);
        setPendingProfiles(all.filter(p => p.status === 'PENDING'));
        const cfg = await finance.getGlobalConfig();
        setPresenceEnabled(cfg?.presenceEnabled ?? true);
      }
    } catch (err) {
      console.error(err);
    } finally {
      setLoading(false);
    }
  };

  // Handlers
  const handleRestore = async (col: string, id: string) => {
    setRestoring(id);
    try {
      await finance.restoreItem(col, id);
      showToast('Nervo de Dados Restaurado!');
      loadData();
    } catch (error) {
      console.error(error);
      showToast('Falha na Restauração');
    } finally {
      setRestoring(null);
    }
  };

  const handlePurge = async () => {
    if (window.confirm('CUIDADO: Isso excluirá permanentemente todos os itens na lixeira com mais de 90 dias. Deseja continuar?')) {
      setPurging(true);
      try {
        const count = await finance.purgeOldDeletedItems(90);
        showToast(`${count} fragmentos purgados com sucesso!`);
        loadData();
      } catch (error) {
        console.error(error);
        showToast('Falha na Purgação');
      } finally {
        setPurging(false);
      }
    }
  };

  const handlePreApprove = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!preApproveEmail) return;
    setIsPreApproving(true);
    try {
      await profilesService.preApproveEmail(preApproveEmail, preApproveRole);
      showToast('Identidade Pré-Autorizada!');
      setPreApproveEmail('');
      loadData();
    } catch (err: any) {
      console.error('Erro na pré-aprovação:', err);
      showToast('Falha na Autorização');
    } finally {
      setIsPreApproving(false);
    }
  };

  const handleUpdateStatus = async (uid: string, status: 'APPROVED' | 'BLOCKED' | 'PENDING') => {
    try {
      await profilesService.updateStatus(uid, status);
      showToast(`Protocolo: ${status}`);
      loadData();
    } catch (e) {
      showToast('Falha no Protocolo');
    }
  };

  const handleTogglePresence = async () => {
    setSavingPresence(true);
    try {
      const next = !presenceEnabled;
      await finance.saveGlobalConfig({ presenceEnabled: next } as any);
      setPresenceEnabled(next);
      showToast(next ? 'Rastreio de presença ativado' : 'Rastreio de presença desativado');
    } catch {
      showToast('Erro ao salvar configuração');
    } finally {
      setSavingPresence(false);
    }
  };

  const handleUpdateRole = async (uid: string, role: 'ADMIN' | 'EDITOR' | 'VIEWER') => {
    try {
      await profilesService.updateRole(uid, role);
      showToast(`Autoridade: ${role}`);
      loadData();
    } catch (e) {
      showToast('Falha na Autoridade');
    }
  };

  const exportBackup = async () => {
    try {
      const [students, classes, services] = await Promise.all([
        finance.getStudents(),
        finance.getClasses(),
        finance.getServices()
      ]);
      
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(students), "Alunos");
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(classes), "Turmas");
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(services), "Serviços");
      
      XLSX.writeFile(wb, `canteen_vault_backup_${new Date().getTime()}.xlsx`);
      showToast('Backup Vault Concluído!');
    } catch (e) {
      console.error(e);
      showToast('Erro no Backup');
    }
  };

  if (!isAdmin) {
    return (
      <div className="flex flex-col items-center justify-center min-h-[calc(100vh-10rem)] text-slate-500 space-y-10">
        <div className="w-32 h-32 bg-red-500/10 rounded-[3rem] flex items-center justify-center text-red-500 animate-pulse border-4 border-red-500/20">
           <ShieldAlert size={64} />
        </div>
        <div className="text-center">
          <h2 className="text-3xl font-black text-slate-900 uppercase tracking-tighter">Acesso Restrito</h2>
          <p className="text-lg font-medium text-slate-400 mt-2">Você não possui as credenciais necessárias para esta zona.</p>
        </div>
        <button onClick={() => navigate('/')} className="bg-slate-900 text-white px-10 py-5 rounded-[1.5rem] font-black uppercase tracking-widest text-[11px] hover:scale-105 transition-all">
           Voltar para Segurança
        </button>
      </div>
    );
  }

  return (
    <div className="p-4 md:p-8 pb-32 max-w-[1600px] mx-auto space-y-12">
      <AnimatePresence>
        {toast && (
          <motion.div 
            initial={{ opacity: 0, y: 50, scale: 0.9 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            exit={{ opacity: 0, y: 50, scale: 0.9 }}
            className="fixed bottom-12 right-12 z-[100] bg-slate-900 text-white px-8 py-5 rounded-[2rem] font-black shadow-2xl flex items-center gap-4 border border-white/10 backdrop-blur-xl"
          >
            <div className="w-10 h-10 bg-brand-blue rounded-xl flex items-center justify-center text-white shadow-lg">
              <Zap size={20} />
            </div>
            <span className="uppercase tracking-widest text-[11px]">{toast}</span>
          </motion.div>
        )}
      </AnimatePresence>

      {/* --- Strategic Header --- */}
      <motion.div 
        initial={{ opacity: 0, y: -20 }} 
        animate={{ opacity: 1, y: 0 }}
        className="flex flex-col xl:flex-row xl:justify-between xl:items-center bg-white p-12 rounded-[4rem] shadow-2xl shadow-slate-200/50 border border-slate-100 gap-10"
      >
        <div className="flex items-center gap-10">
          <div className="w-28 h-28 bg-brand-blue rounded-[3rem] flex items-center justify-center text-white shadow-3xl shadow-brand-blue/30 relative overflow-hidden group">
            <div className="absolute inset-0 bg-gradient-to-br from-white/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            <Shield size={48} className="relative z-10" />
          </div>
          <div>
            <div className="flex items-center gap-3 mb-3">
               <span className="px-4 py-1.5 bg-brand-blue/10 text-brand-blue rounded-full text-[10px] font-black uppercase tracking-widest border border-brand-blue/20">Segurança</span>
               <span className="px-4 py-1.5 bg-slate-900/10 text-slate-900 rounded-full text-[10px] font-black uppercase tracking-widest border border-slate-900/20">Núcleo Operacional</span>
            </div>
            <h1 className="text-6xl font-black text-slate-900 uppercase tracking-tighter leading-none">Central do <span className="text-brand-blue">Sistema</span></h1>
            <p className="text-slate-400 font-medium mt-4 text-xl italic leading-relaxed">Governança de identidades, auditoria forense e integridade estrutural.</p>
          </div>
        </div>

        <div className="flex flex-wrap items-center gap-6 bg-slate-50 p-4 rounded-[4rem] border border-slate-100 shadow-inner">
           <div className="px-10 py-6 bg-white rounded-[2rem] border border-slate-200 shadow-sm flex items-center gap-6">
              <div className="w-14 h-14 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-600 border border-emerald-500/10">
                 <ShieldCheck size={28} />
              </div>
              <div>
                 <p className="text-[11px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Saúde do Sistema</p>
                 <p className="text-xl font-black text-slate-900">Ótimo (2.4ms)</p>
              </div>
           </div>
           <div className="px-10 py-6 bg-white rounded-[2rem] border border-slate-200 shadow-sm flex items-center gap-6">
              <div className="w-14 h-14 bg-amber-500/10 rounded-2xl flex items-center justify-center text-amber-600 border border-amber-500/10">
                 <Cpu size={28} />
              </div>
              <div>
                 <p className="text-[11px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">Carga do Sistema</p>
                 <p className="text-xl font-black text-slate-900">Estável</p>
              </div>
           </div>
        </div>
      </motion.div>

      {/* --- Navigation Tabs --- */}
      <div className="flex flex-wrap bg-white p-3 rounded-[3.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 gap-3">
        {(['audit', 'access', 'maintenance', 'danger'] as TabType[]).map((tab) => (
          <motion.button
            whileHover={{ y: -2 }}
            whileTap={{ scale: 0.98 }}
            key={tab}
            onClick={() => setActiveTab(tab)}
            className={cn(
              "flex-1 min-w-[180px] flex items-center justify-center gap-4 py-6 rounded-[2.5rem] font-black uppercase tracking-[0.2em] text-[11px] transition-all relative overflow-hidden",
              activeTab === tab 
                ? 'bg-slate-900 text-white shadow-2xl shadow-slate-900/20' 
                : 'text-slate-400 hover:bg-slate-50 hover:text-slate-600 border border-transparent'
            )}
          >
            {tab === 'audit' && <History size={18} />}
            {tab === 'access' && <Fingerprint size={18} />}
            {tab === 'maintenance' && <Database size={18} />}
            {tab === 'danger' && <ShieldAlert size={18} />}
            {tab === 'audit' ? 'Auditoria' : 
             tab === 'access' ? 'Acessos' : 
             tab === 'maintenance' ? 'Lixeira' : 'Perigo'}
            {activeTab === tab && <motion.div layoutId="tab-pill" className="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent pointer-events-none" />}
          </motion.button>
        ))}
      </div>

      {/* --- Tab Content --- */}
      <motion.div
        key={activeTab}
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ duration: 0.4 }}
        className="space-y-10"
      >
        {activeTab === 'audit' && (
          <div className="bg-white rounded-[4rem] shadow-2xl shadow-slate-200/40 border border-slate-100 overflow-hidden">
            <div className="flex bg-slate-50/50 border-b border-slate-100">
              <button
                onClick={() => setAuditSubTab('logs')}
                className={cn(
                  "flex-1 py-10 font-black text-xs uppercase tracking-[0.3em] flex items-center justify-center gap-4 transition-all relative",
                  auditSubTab === 'logs' ? 'text-brand-blue bg-white' : 'text-slate-400 hover:text-slate-600'
                )}
              >
                <Terminal size={20} /> Logs de Atividade Forense
                {auditSubTab === 'logs' && <motion.div layoutId="audit-active" className="absolute bottom-0 left-1/2 -translate-x-1/2 w-32 h-1.5 bg-brand-blue rounded-t-full shadow-lg" />}
              </button>
              <button
                onClick={() => setAuditSubTab('trash')}
                className={cn(
                  "flex-1 py-10 font-black text-xs uppercase tracking-[0.3em] flex items-center justify-center gap-4 transition-all relative",
                  auditSubTab === 'trash' ? 'text-brand-blue bg-white' : 'text-slate-400 hover:text-slate-600'
                )}
              >
                <Trash size={20} /> Lixeira de Recuperação
                {auditSubTab === 'trash' && <motion.div layoutId="audit-active" className="absolute bottom-0 left-1/2 -translate-x-1/2 w-32 h-1.5 bg-brand-blue rounded-t-full shadow-lg" />}
              </button>
            </div>

            {loading ? (
              <div className="p-32 flex flex-col items-center gap-6">
                 <div className="w-16 h-16 border-4 border-brand-blue/10 border-t-brand-blue rounded-full animate-spin" />
                 <p className="text-[11px] font-black text-slate-400 uppercase tracking-[0.4em]">Indexando Logs...</p>
              </div>
            ) : auditSubTab === 'logs' ? (
              <div className="overflow-x-auto">
                <table className="w-full text-left">
                  <thead className="bg-slate-50/80 text-slate-400 font-black uppercase tracking-[0.3em] text-[10px] border-b border-slate-100">
                    <tr>
                      <th className="px-12 py-8">Data/Hora</th>
                      <th className="px-12 py-8">Usuário</th>
                      <th className="px-12 py-8">Operação</th>
                      <th className="px-12 py-8">Coleção</th>
                      <th className="px-12 py-8">ID do Registro</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-50">
                    {logs.length === 0 ? (
                      <tr><td colSpan={5} className="px-12 py-32 text-center text-slate-400 font-black uppercase tracking-[0.2em] italic">Nenhuma atividade registrada no lote.</td></tr>
                    ) : (
                      logs.map((log) => (
                        <tr key={log.id} className="hover:bg-slate-50/80 transition-colors group">
                          <td className="px-12 py-8 text-slate-500 whitespace-nowrap font-black tabular-nums text-xs">
                            {new Date(log.timestamp).toLocaleString('pt-BR')}
                          </td>
                          <td className="px-12 py-8">
                            <div className="flex flex-col">
                              <span className="text-slate-900 font-black text-sm uppercase tracking-tighter">{log.userEmail.split('@')[0]}</span>
                              <span className="text-[10px] text-slate-400 font-black uppercase tracking-widest mt-1 opacity-60">{log.userEmail}</span>
                            </div>
                          </td>
                          <td className="px-12 py-8">
                            <span className={cn(
                              "px-4 py-1.5 rounded-xl text-[10px] font-black tracking-[0.2em] uppercase border shadow-sm",
                              log.action === 'CREATE' ? 'bg-emerald-50 text-emerald-600 border-emerald-100 shadow-emerald-500/5' :
                              log.action === 'UPDATE' ? 'bg-brand-blue/5 text-brand-blue border-brand-blue/10 shadow-brand-blue/5' :
                              log.action === 'SOFT_DELETE' ? 'bg-amber-50 text-amber-600 border-amber-100 shadow-amber-500/5' :
                              'bg-red-50 text-red-600 border-red-100 shadow-red-500/5'
                            )}>
                              {log.action}
                            </span>
                          </td>
                          <td className="px-12 py-8 text-slate-900 font-black text-xs uppercase tracking-widest">{log.collectionName}</td>
                          <td className="px-12 py-8">
                             <div className="flex items-center gap-3">
                                <div className="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center text-slate-400">
                                   <Ghost size={14} />
                                </div>
                                <span className="font-mono text-xs text-slate-400 truncate max-w-[150px]">{log.documentId}</span>
                             </div>
                          </td>
                        </tr>
                      ))
                    )}
                  </tbody>
                </table>
              </div>
            ) : (
              <div className="p-12 space-y-12">
                <motion.div 
                  initial={{ opacity: 0, scale: 0.98 }}
                  animate={{ opacity: 1, scale: 1 }}
                  className="bg-slate-900 p-12 rounded-[3.5rem] flex flex-col xl:flex-row justify-between items-center gap-10 relative overflow-hidden group"
                >
                  <div className="absolute top-0 right-0 w-96 h-96 bg-amber-500/10 blur-[100px] rounded-full -mr-48 -mt-48 group-hover:bg-amber-500/20 transition-all duration-1000" />
                  <div className="flex items-center gap-8 relative z-10">
                    <div className="w-20 h-20 bg-amber-500/10 rounded-[2.5rem] flex items-center justify-center text-amber-500 border border-amber-500/20 shadow-2xl">
                       <Clock size={36} />
                    </div>
                    <div>
                      <h3 className="text-2xl font-black text-white uppercase tracking-tighter">Políticas de Retenção (90 dias)</h3>
                      <p className="text-lg text-slate-400 font-medium mt-2 leading-relaxed max-w-xl">
                         Arquivos excluídos permanecem no sistema por 90 dias. A limpeza manual remove permanentemente registros antigos do banco de dados.
                      </p>
                    </div>
                  </div>
                  <motion.button 
                    whileHover={{ scale: 1.05 }}
                    whileTap={{ scale: 0.95 }}
                    onClick={handlePurge}
                    disabled={purging}
                    className="relative z-10 px-12 py-6 bg-white text-slate-900 rounded-[2rem] font-black uppercase tracking-[0.3em] text-[11px] disabled:opacity-50 shadow-2xl shadow-white/10 flex items-center gap-4"
                  >
                    {purging ? <Activity size={18} className="animate-spin" /> : <Trash size={18} />}
                    {purging ? 'Limpando...' : 'Limpar Registros > 90d'}
                  </motion.button>
                </motion.div>

                <div className="overflow-hidden border border-slate-100 rounded-[3.5rem] shadow-xl shadow-slate-200/30">
                  <table className="w-full text-left">
                    <thead className="bg-slate-50 text-slate-400 font-black uppercase tracking-[0.3em] text-[10px] border-b border-slate-100">
                      <tr>
                        <th className="px-12 py-8">Deletado em</th>
                        <th className="px-12 py-8">Operador</th>
                        <th className="px-12 py-8">Coleção</th>
                        <th className="px-12 py-8">Identificação</th>
                        <th className="px-12 py-8 text-right">Ação Corretiva</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100">
                      {deletedItems.length === 0 ? (
                        <tr><td colSpan={5} className="px-12 py-20 text-center text-slate-400 font-black uppercase tracking-[0.2em] italic">Lixeira de recuperação vazia.</td></tr>
                      ) : (
                        deletedItems.map((item) => (
                          <tr key={item.id} className="hover:bg-slate-50 transition-colors">
                            <td className="px-12 py-8 text-slate-500 whitespace-nowrap font-black tabular-nums text-xs">{new Date(item.deletedAt).toLocaleString('pt-BR')}</td>
                            <td className="px-12 py-8 text-slate-900 font-black text-xs uppercase tracking-tighter">{item.deletedBy || 'System Protocol'}</td>
                            <td className="px-12 py-8"><span className="px-3 py-1 bg-slate-100 text-slate-500 rounded-lg font-black text-[9px] uppercase tracking-widest">{item._collectionName}</span></td>
                            <td className="px-12 py-8 text-slate-900 font-black text-sm tracking-tight truncate max-w-xs">
                              {item.name || item.studentName || item.nossoNumero || item.monthYear || item.id}
                            </td>
                            <td className="px-12 py-8 text-right">
                              <button
                                onClick={() => handleRestore(item._collection, item.id)}
                                disabled={restoring === item.id}
                                className="px-8 py-3 bg-brand-blue text-white rounded-2xl font-black uppercase tracking-widest text-[10px] shadow-lg shadow-brand-blue/20 hover:scale-105 transition-all disabled:opacity-50 flex items-center gap-3 ml-auto"
                              >
                                {restoring === item.id ? <Activity size={14} className="animate-spin" /> : <RotateCcw size={14} />}
                                {restoring === item.id ? 'Restaurando...' : 'Restaurar'}
                              </button>
                            </td>
                          </tr>
                        ))
                      )}
                    </tbody>
                  </table>
                </div>
              </div>
            )}
          </div>
        )}

        {activeTab === 'access' && (
          <div className="grid grid-cols-1 xl:grid-cols-12 gap-12">
            <div className="xl:col-span-4 space-y-12">
              {/* Pre-approval form */}
              <div className="bg-white p-12 rounded-[4rem] shadow-2xl shadow-slate-200/40 border border-slate-100 relative overflow-hidden group">
                <div className="absolute top-0 right-0 w-32 h-32 bg-brand-blue/5 rounded-bl-[4rem] flex items-center justify-center group-hover:scale-110 transition-transform">
                   <Key size={32} className="text-brand-blue opacity-20" />
                </div>
                <h3 className="text-2xl font-black text-slate-900 uppercase tracking-tighter mb-10 flex items-center gap-4">
                  <UserCheck className="text-brand-blue" size={32} /> Pré-Autorização de Acesso
                </h3>
                <form onSubmit={handlePreApprove} className="space-y-8">
                  <div className="space-y-3">
                    <label className="block text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] px-2">E-mail</label>
                    <input 
                      type="email" 
                      placeholder="identity@vault.com"
                      value={preApproveEmail}
                      onChange={e => setPreApproveEmail(e.target.value)}
                      className="w-full bg-slate-50 border-2 border-slate-100 rounded-[1.8rem] px-8 py-6 text-base font-black text-slate-900 placeholder:text-slate-300 focus:ring-4 focus:ring-brand-blue/5 focus:border-brand-blue/20 outline-none transition-all"
                      required
                    />
                  </div>
                  <div className="space-y-3">
                    <label className="block text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] px-2">Nível de Acesso</label>
                    <select 
                      value={preApproveRole}
                      onChange={e => setPreApproveRole(e.target.value as any)}
                      className="w-full bg-slate-50 border-2 border-slate-100 rounded-[1.8rem] px-8 py-6 text-base font-black uppercase tracking-widest text-slate-900 focus:ring-4 focus:ring-brand-blue/5 focus:border-brand-blue/20 outline-none cursor-pointer appearance-none"
                    >
                      <option value="EDITOR">Editor</option>
                      <option value="VIEWER">Visualizador</option>
                      <option value="ADMIN">Administrador</option>
                    </select>
                  </div>
                  <motion.button 
                    whileHover={{ scale: 1.02 }}
                    whileTap={{ scale: 0.98 }}
                    type="submit"
                    disabled={isPreApproving || !isSuperAdmin}
                    className="w-full bg-brand-blue text-white py-6 rounded-[2rem] font-black uppercase tracking-[0.3em] text-[11px] hover:bg-brand-blue/90 transition-all shadow-2xl shadow-brand-blue/20 disabled:opacity-50 mt-4 flex items-center justify-center gap-4"
                  >
                    {isPreApproving ? <Activity size={20} className="animate-spin" /> : <Lock size={20} />}
                    Autorizar Acesso
                  </motion.button>
                  {!isSuperAdmin && (
                    <motion.div 
                      initial={{ opacity: 0 }} animate={{ opacity: 1 }}
                      className="p-5 bg-red-50 rounded-3xl border border-red-100 flex items-center gap-4"
                    >
                       <AlertTriangle className="text-red-500" size={18} />
                       <p className="text-[10px] text-red-600 font-black uppercase tracking-widest leading-relaxed">Pré-autorização restrita ao SuperAdmin.</p>
                    </motion.div>
                  )}
                </form>
              </div>

              {/* Presence Toggle */}
              <div className="bg-white p-10 rounded-[3.5rem] shadow-xl shadow-slate-200/30 border border-slate-100 relative overflow-hidden">
                <div className="absolute top-0 right-0 w-24 h-24 bg-emerald-50 rounded-bl-[3rem] flex items-center justify-center">
                  <Activity size={24} className="text-emerald-400" />
                </div>
                <h3 className="text-[11px] font-black text-slate-400 uppercase tracking-[0.3em] mb-2 flex items-center gap-3">
                  <Eye size={14} /> Rastreio de Presença
                </h3>
                <p className="text-[10px] text-slate-400 font-medium mb-8 leading-relaxed">
                  Exibe a barra "Online Agora" no topo do sistema com os usuários ativos.
                </p>
                <button
                  onClick={handleTogglePresence}
                  disabled={savingPresence || !isAdmin}
                  className={`w-full flex items-center justify-between px-8 py-5 rounded-[2rem] font-black text-[11px] uppercase tracking-widest transition-all disabled:opacity-50 ${
                    presenceEnabled
                      ? 'bg-emerald-500 text-white shadow-lg shadow-emerald-500/20 hover:bg-emerald-600'
                      : 'bg-slate-100 text-slate-500 hover:bg-slate-200'
                  }`}
                >
                  <span>{presenceEnabled ? 'Ativado' : 'Desativado'}</span>
                  {savingPresence
                    ? <Activity size={16} className="animate-spin" />
                    : <div className={`w-10 h-5 rounded-full relative transition-all ${presenceEnabled ? 'bg-white/30' : 'bg-slate-300'}`}>
                        <div className={`absolute top-0.5 w-4 h-4 rounded-full bg-white shadow transition-all ${presenceEnabled ? 'left-5' : 'left-0.5'}`} />
                      </div>
                  }
                </button>
              </div>

              {/* Identity Stats */}
              <div className="bg-slate-900 p-12 rounded-[4rem] text-white shadow-2xl shadow-slate-200 overflow-hidden relative group">
                <div className="absolute bottom-0 right-0 w-64 h-64 bg-brand-blue/10 blur-[100px] rounded-full -mb-32 -mr-32" />
                <h3 className="text-[11px] font-black text-slate-400 uppercase tracking-[0.4em] mb-10 flex items-center gap-3">
                   <Activity size={16} className="text-brand-blue" /> Usuários Registrados
                </h3>
                <div className="space-y-10 relative z-10">
                  <div className="flex justify-between items-end">
                    <div>
                      <p className="text-6xl font-black tabular-nums tracking-tighter leading-none">{profiles.length}</p>
                      <p className="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mt-3">Usuários</p>
                    </div>
                    <div className="text-right">
                      <p className="text-3xl font-black text-amber-400 tabular-nums tracking-tighter leading-none">{pendingProfiles.length}</p>
                      <p className="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mt-2">Aguardando Aprovação</p>
                    </div>
                  </div>
                  <div className="space-y-4">
                     <div className="flex justify-between text-[10px] font-black uppercase tracking-widest text-slate-500">
                        <span>Progresso de Aprovação</span>
                        <span>{Math.round((profiles.filter(p => p.status === 'APPROVED').length / profiles.length) * 100)}%</span>
                     </div>
                    <div className="h-4 bg-white/5 rounded-full overflow-hidden flex border border-white/5 p-1">
                      <div className="bg-emerald-500 h-full rounded-full shadow-lg shadow-emerald-500/20 transition-all duration-1000" style={{ width: `${(profiles.filter(p => p.status === 'APPROVED').length / profiles.length) * 100}%` }} />
                      <div className="bg-amber-500 h-full rounded-full shadow-lg shadow-amber-500/20 transition-all duration-1000 mx-1" style={{ width: `${(pendingProfiles.length / profiles.length) * 100}%` }} />
                      <div className="bg-red-500 h-full rounded-full shadow-lg shadow-red-500/20 transition-all duration-1000" style={{ width: `${(profiles.filter(p => p.status === 'BLOCKED').length / profiles.length) * 100}%` }} />
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div className="xl:col-span-8 space-y-10">
              {/* Identity List */}
              <div className="bg-white rounded-[4.5rem] shadow-2xl shadow-slate-200/40 border border-slate-100 overflow-hidden">
                <div className="p-12 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                  <h3 className="text-2xl font-black text-slate-900 uppercase tracking-tighter">Identity Management Cluster</h3>
                  <div className="flex items-center gap-4 bg-white px-6 py-3 rounded-full border border-slate-200 shadow-sm">
                    <span className="w-3 h-3 bg-amber-500 rounded-full animate-pulse" />
                    <span className="text-[11px] font-black text-slate-900 uppercase tracking-[0.2em]">
                      {pendingProfiles.length} Pendentes
                    </span>
                  </div>
                </div>

                <div className="divide-y divide-slate-100">
                  {/* Pending Identities */}
                  <AnimatePresence>
                    {pendingProfiles.map(p => (
                      <motion.div 
                        initial={{ opacity: 0, x: -20 }}
                        animate={{ opacity: 1, x: 0 }}
                        exit={{ opacity: 0, x: 20 }}
                        key={p.uid} 
                        className="p-10 bg-amber-50/30 flex flex-col md:flex-row items-center justify-between gap-8 group"
                      >
                        <div className="flex items-center gap-8">
                          <div className="w-20 h-20 bg-amber-100 rounded-[2rem] flex items-center justify-center text-amber-600 shadow-lg border-4 border-white"><Clock size={32} /></div>
                          <div>
                            <div className="flex items-center gap-3 mb-1">
                               <span className="px-3 py-1 bg-amber-600 text-white rounded-lg text-[9px] font-black uppercase tracking-widest shadow-md shadow-amber-500/20">Aguardando</span>
                               <p className="font-black text-slate-900 uppercase text-lg tracking-tighter">{p.displayName || 'Sem Nome'}</p>
                            </div>
                            <p className="text-[11px] font-black text-slate-400 uppercase tracking-widest opacity-60">{p.email}</p>
                          </div>
                        </div>
                        <div className="flex gap-4">
                          <motion.button 
                            whileHover={{ scale: 1.05 }}
                            whileTap={{ scale: 0.95 }}
                            onClick={() => handleUpdateStatus(p.uid, 'APPROVED')}
                            disabled={!isSuperAdmin}
                            className="px-10 py-5 bg-emerald-500 text-white rounded-[1.5rem] font-black uppercase tracking-[0.2em] text-[10px] hover:bg-emerald-600 transition-all shadow-xl shadow-emerald-500/20 disabled:opacity-50"
                          >Autorizar</motion.button>
                          <motion.button
                            whileHover={{ scale: 1.05 }}
                            whileTap={{ scale: 0.95 }}
                            onClick={() => handleUpdateStatus(p.uid, 'BLOCKED')}
                            disabled={!isSuperAdmin}
                            className="px-10 py-5 bg-white border-2 border-red-200 text-red-500 rounded-[1.5rem] font-black uppercase tracking-[0.2em] text-[10px] hover:bg-red-50 transition-all disabled:opacity-50"
                          >Recusar</motion.button>
                        </div>
                      </motion.div>
                    ))}
                  </AnimatePresence>

                  {/* Registered Identities */}
                  {profiles.filter(p => p.status !== 'PENDING').map(p => (
                    <div key={p.uid} className="p-10 flex flex-col md:flex-row items-center justify-between gap-8 hover:bg-slate-50 transition-all group">
                      <div className="flex items-center gap-8">
                        <div className={cn(
                          "w-20 h-20 rounded-[2rem] flex items-center justify-center shadow-xl border-4 border-white transition-transform group-hover:scale-105",
                          p.status === 'APPROVED' ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600'
                        )}>
                          {p.status === 'APPROVED' ? <UserCheck size={32} /> : <UserX size={32} />}
                        </div>
                        <div>
                          <div className="flex items-center gap-4 mb-2">
                            <p className="font-black text-slate-900 uppercase text-xl tracking-tighter">{p.displayName}</p>
                            <span className={cn(
                              "px-3 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest shadow-sm",
                              p.role === 'ADMIN' ? 'bg-indigo-600 text-white shadow-indigo-500/20' : 'bg-slate-900 text-white shadow-slate-900/20'
                            )}>{p.role}</span>
                            {p.status === 'BLOCKED' && <span className="px-3 py-1 bg-red-600 text-white rounded-lg text-[9px] font-black uppercase tracking-widest">Bloqueado</span>}
                          </div>
                          <p className="text-[11px] font-black text-slate-400 uppercase tracking-widest opacity-60">{p.email}</p>
                        </div>
                      </div>
                      <div className="flex items-center gap-6">
                        <div className="relative group/select">
                           <div className="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400 group-hover/select:text-brand-blue transition-colors">
                              <ChevronDown size={14} />
                           </div>
                           <select 
                            value={p.role} 
                            onChange={(e) => handleUpdateRole(p.uid, e.target.value as any)}
                            disabled={!isSuperAdmin || p.uid === currentUserProfile?.uid}
                            className="appearance-none bg-slate-100 border-none rounded-2xl pl-6 pr-12 py-4 text-[10px] font-black uppercase tracking-[0.2em] text-slate-900 focus:ring-4 focus:ring-brand-blue/5 cursor-pointer disabled:opacity-50 transition-all"
                          >
                            <option value="EDITOR">Editor</option>
                            <option value="VIEWER">Visualizador</option>
                            <option value="ADMIN">Administrador</option>
                          </select>
                        </div>
                        <motion.button 
                          whileHover={{ scale: 1.1, rotate: 5 }}
                          whileTap={{ scale: 0.9 }}
                          onClick={() => handleUpdateStatus(p.uid, p.status === 'APPROVED' ? 'BLOCKED' : 'APPROVED')}
                          disabled={!isSuperAdmin || p.uid === currentUserProfile?.uid}
                          className={cn(
                            "p-5 rounded-2xl transition-all shadow-lg border-2",
                            p.status === 'APPROVED' ? 'text-red-500 bg-red-50 border-red-100 hover:bg-red-500 hover:text-white' : 'text-emerald-500 bg-emerald-50 border-emerald-100 hover:bg-emerald-500 hover:text-white',
                            (!isSuperAdmin || p.uid === currentUserProfile?.uid) && "opacity-0 pointer-events-none"
                          )}
                        >
                          {p.status === 'APPROVED' ? <UserX size={24} /> : <UserCheck size={24} />}
                        </motion.button>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        )}

        {activeTab === 'maintenance' && (
          <div className="grid grid-cols-1 xl:grid-cols-2 gap-12">
            {/* Backup Hub */}
            <motion.div 
              whileHover={{ y: -8 }}
              className="bg-white p-12 rounded-[4.5rem] shadow-2xl shadow-slate-200/40 border border-slate-100 flex flex-col justify-between group hover:border-brand-blue/30 transition-all relative overflow-hidden"
            >
              <div className="absolute top-0 right-0 w-64 h-64 bg-brand-blue/5 rounded-bl-full -mr-32 -mt-32" />
              <div>
                <div className="w-24 h-24 bg-brand-blue/5 rounded-[2.5rem] flex items-center justify-center text-brand-blue mb-10 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500 shadow-inner">
                  <Database size={48} />
                </div>
                <h3 className="text-3xl font-black text-slate-900 uppercase tracking-tighter mb-6">Backup Estratégico</h3>
                <p className="text-xl text-slate-400 font-medium mb-12 leading-relaxed max-w-xl">
                  Snapshot total de identidades, turmas operacionais e protocolos financeiros. Essencial antes de manutenções críticas ou encerramento de ciclos fiscais.
                </p>
              </div>
              <motion.button 
                whileHover={{ scale: 1.02 }}
                whileTap={{ scale: 0.98 }}
                onClick={exportBackup}
                className="w-full bg-slate-900 text-white py-8 rounded-[2.5rem] font-black uppercase tracking-[0.3em] text-[11px] hover:bg-black transition-all shadow-2xl shadow-slate-900/20 flex items-center justify-center gap-4 group/btn"
              >
                <Download size={24} className="text-brand-lime group-hover:translate-y-1 transition-transform" /> Executar Exportação Total do Sistema
              </motion.button>
            </motion.div>

            {/* System Diagnostic */}
            <div className="bg-slate-900 p-12 rounded-[4.5rem] border border-slate-800 shadow-3xl shadow-slate-900/40 relative overflow-hidden group">
              <div className="absolute bottom-0 right-0 w-96 h-96 bg-brand-blue/5 blur-[120px] rounded-full -mb-48 -mr-48" />
              <h3 className="text-[11px] font-black text-slate-500 uppercase tracking-[0.4em] mb-10 flex items-center gap-4 relative z-10">
                <Activity size={18} className="text-brand-blue" /> Diagnóstico do Sistema
              </h3>
              <div className="space-y-6 relative z-10">
                {[
                  { label: 'Versão', value: '2026.1', icon: Terminal, color: 'text-brand-blue' },
                  { label: 'Motor de Cálculo', value: 'Antigravity v4', icon: Cpu, color: 'text-brand-lime' },
                  { label: 'Ambiente', value: 'PRODUÇÃO', icon: ShieldCheck, color: 'text-emerald-500' },
                  { label: 'Protocolo de Identidade', value: 'Criptografado V2', icon: Fingerprint, color: 'text-indigo-500' }
                ].map((stat, i) => (
                  <motion.div 
                    initial={{ opacity: 0, x: 20 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ delay: i * 0.1 }}
                    key={i} 
                    className="flex justify-between items-center p-8 bg-white/5 rounded-[2rem] border border-white/5 hover:bg-white/10 transition-colors"
                  >
                    <div className="flex items-center gap-6">
                       <div className={cn("w-12 h-12 rounded-2xl flex items-center justify-center bg-white/5 shadow-inner", stat.color.replace('text', 'text-opacity-20'))}>
                          <stat.icon size={24} className={stat.color} />
                       </div>
                       <span className="text-[11px] font-black text-slate-400 uppercase tracking-widest">{stat.label}</span>
                    </div>
                    <span className="text-base font-black text-white uppercase tracking-tighter">{stat.value}</span>
                  </motion.div>
                ))}
              </div>
              
              <div className="mt-12 p-8 bg-brand-blue/5 rounded-[2.5rem] border border-brand-blue/10 flex items-center justify-between relative z-10">
                 <div className="flex items-center gap-6">
                    <div className="w-4 h-4 bg-emerald-500 rounded-full animate-ping" />
                    <p className="text-white font-black uppercase text-xs tracking-widest">Monitoramento: <span className="text-emerald-500">Ativo</span></p>
                 </div>
                 <ArrowRight size={24} className="text-brand-blue opacity-40 group-hover:translate-x-2 transition-transform" />
              </div>
            </div>
          </div>
        )}

        {activeTab === 'danger' && (
          <motion.div 
            initial={{ opacity: 0, scale: 0.95 }}
            animate={{ opacity: 1, scale: 1 }}
            className="max-w-4xl mx-auto space-y-10"
          >
            <div className="bg-red-600 p-16 rounded-[5rem] text-center space-y-12 shadow-3xl shadow-red-200 border-8 border-white relative overflow-hidden group">
              <div className="absolute inset-0 bg-gradient-to-br from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-1000" />
              <div className="w-32 h-32 bg-white rounded-[3rem] flex items-center justify-center text-red-600 mx-auto shadow-2xl relative z-10 group-hover:rotate-12 transition-transform duration-500">
                <ShieldAlert size={64} />
              </div>
              <div className="relative z-10">
                <h2 className="text-5xl font-black text-white uppercase tracking-tighter mb-6 leading-none">Zona de <span className="text-slate-900">Exclusão Total</span></h2>
                <p className="text-2xl text-white/80 font-medium leading-relaxed max-w-2xl mx-auto">
                  A exclusão de dados é <span className="text-white font-black underline decoration-4 underline-offset-8">absoluta e irreversível</span>. Todos os registros, auditorias e identidades serão removidos do sistema permanentemente.
                </p>
              </div>
              
              <div className="pt-12 border-t border-white/20 relative z-10">
                <motion.button 
                  whileHover={{ scale: 1.05, rotate: -1 }}
                  whileTap={{ scale: 0.95 }}
                  onClick={() => setIsDeleteModalOpen(true)}
                  className="px-16 py-8 bg-slate-900 text-white rounded-[2.5rem] font-black uppercase tracking-[0.4em] text-sm hover:bg-black transition-all shadow-3xl shadow-black/20 flex items-center justify-center gap-6 mx-auto group/danger"
                >
                  <Trash2 size={24} className="text-red-500 group-hover:scale-125 transition-transform" />
                  Protocolo de Reinicialização Total
                </motion.button>
                <div className="flex items-center justify-center gap-4 mt-10">
                   <Lock size={16} className="text-white/40" />
                   <p className="text-[11px] text-white/50 font-black uppercase tracking-[0.4em]">
                     Confirmação de Dupla Autenticação Obrigatória
                   </p>
                </div>
              </div>
            </div>

            <div className="p-10 bg-slate-50 rounded-[3rem] border-2 border-slate-100 flex items-center gap-8 group">
               <div className="w-16 h-16 bg-white rounded-[1.5rem] flex items-center justify-center text-slate-400 group-hover:text-brand-blue transition-colors shadow-sm">
                  <ShieldCheck size={28} />
               </div>
               <div className="flex-1">
                  <h4 className="text-lg font-black text-slate-900 uppercase tracking-tighter leading-none">Security Safeguard</h4>
                  <p className="text-slate-400 font-medium mt-2">Mesmo com o reset, logs de auditoria de nível 4 (acessos) são mantidos em cache frio por 365 dias para conformidade legal.</p>
               </div>
            </div>
          </motion.div>
        )}
      </motion.div>

      {/* --- Footer Signature --- */}
      <div className="flex flex-col md:flex-row justify-between items-center pt-16 border-t border-slate-100 gap-8 opacity-30 group hover:opacity-100 transition-opacity">
        <div className="flex items-center gap-4">
           <Fingerprint size={24} className="text-slate-400 group-hover:text-brand-blue transition-colors" />
           <p className="text-[11px] font-black text-slate-400 uppercase tracking-[0.4em]">Segurança &bull; 2026</p>
        </div>
        <div className="flex items-center gap-10">
           <div className="flex items-center gap-4">
              <Zap size={16} className="text-brand-blue animate-pulse" />
              <p className="text-[11px] font-black text-slate-400 uppercase tracking-[0.4em]">Antigravity Intelligence Core v4.2</p>
           </div>
           <p className="text-[11px] font-black text-slate-400 uppercase tracking-[0.4em]">System Center Verified</p>
        </div>
      </div>

      <DeleteDataModal 
        isOpen={isDeleteModalOpen} 
        onClose={() => setIsDeleteModalOpen(false)} 
        onSuccess={() => {
          showToast('Limpeza Nuclear Concluída');
          loadData();
        }}
      />
    </div>
  );
}
