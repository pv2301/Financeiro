rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "paulo.vlima@prf.gov.br" && request.auth.token.email_verified == true));
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == userId && request.resource.data.role == 'user') || isAdmin();
      allow update: if isAuthenticated() && (request.auth.uid == userId && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /fin_students/{studentId} {
      allow read, write: if isAuthenticated();
    }

    match /fin_classes/{classId} {
      allow read, write: if isAuthenticated();
    }

    match /fin_snacks/{snackId} {
      allow read, write: if isAuthenticated();
    }

    match /fin_invoices/{invoiceId} {
      allow read, write: if isAuthenticated();
    }

    match /fin_config/{configId} {
      allow read, write: if isAuthenticated();
    }

    match /fin_consumption/{consumptionId} {
      allow read, write: if isAuthenticated();
    }
  }
}
