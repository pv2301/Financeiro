rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions (Unified)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "yUvj3iONfJUNiEvdRS8REf4AzB13" ||
        ('email' in request.auth.token && (
          request.auth.token.email == "paulo.vlima@prf.gov.br" ||
          request.auth.token.email == "paulovictorsilva2301@gmail.com" ||
          request.auth.token.email == "simonecarneirodacunha@hotmail.com"
        ))
      );
    }

    function getProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    // True for any user approved by an admin or the admin themselves
    function isApproved() {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && getProfile().status == 'APPROVED')
      );
    }

    // True for approved users who can write
    function canWrite() {
      return isAdmin() || (
        isApproved() &&
        getProfile().role != 'VIEWER'
      );
    }

    // ===============================================================
    // Cardápio Baby Collections
    // ===============================================================

    match /items/{itemId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /recipes/{recipeId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /substitutions/{subId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /menu/{dayId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /groups/{groupId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /config/{configId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /menuSnapshots/{snapshotId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    // ===============================================================
    // Financeiro Canteen Collections (fin_*)
    // ===============================================================

    match /profiles/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /fin_students/{studentId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /fin_classes/{classId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /fin_snacks/{snackId} {
      allow read: if true; // Public list of snacks/items
      allow write: if canWrite();
    }

    match /fin_invoices/{invoiceId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /fin_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fin_presence/{userId} {
      allow read, list: if isApproved();
      allow write: if isApproved() && (request.auth.uid == userId);
    }

    match /fin_consumption/{consumptionId} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /fin_audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /fin_billing_drafts/{draftId} {
      allow read, write: if isAdmin();
    }
  }
}
